groups {
    basic {
        system {
            host-name {{ hostname }};
            root-authentication {
                encrypted-password "$1$vQqOn2iC$TlvjMurEPB9eo.O21zhn9/"; ## SECRET-DATA
            }
            login {
                user admin {
                    uid 2002;
                    class super-user;
                    authentication {
                        encrypted-password "$1$YCVjYya0$XCHE72IU.gSSkBaHHB8uS."; ## SECRET-DATA
                    }
                }
            }
            services {
                ssh;
                netconf {
                    ssh;
                }
            }
        }
        routing-options {
            router-id {{ loopback }};
            forwarding-table {
                ecmp-fast-reroute;
            }
        }
    }
    OSPF {
            protocols {
                ospf {
                    traffic-engineering;
                    area 0.0.0.0 {
                    interface <ge-*> {
                        interface-type p2p;
                        link-protection;
                        ldp-synchronization;
                        bfd-liveness-detection {
                            minimum-interval 300;
                            multiplier 3;
                            }
                        }
                        interface em0.0 {
                            disable;
                        }
                        interface fxp0.0 {
                            disable;
                        }
                        interface lo0.0 {
                            passive;
                        }
                    }
                }
            }
        }
    }
apply-groups basic;
interfaces {
    {{ interface }} {
        flexible-vlan-tagging;
        encapsulation flexible-ethernet-services;
        {% for unit in units %}
        unit {{ unit.unit }} {
        description "HOST:{{ unit.neighbor }}|PORT:GE-0/0/0|UNIT:{{ unit.unit }}"
            vlan-id {{ unit.vlan }};
            family inet {
                address {{ unit.ip }}/{{ unit.mask }};
            }
        }
        {% endfor %}
    }
    em0 {
        unit 0 {
            family inet {
                address {{ mgmt }}/24;
            }
        }
    }
    lo0 {
        unit 0 {
            family inet {
                address {{ loopback }}/32;
            }
        }
    }
}
routing-options {
    static {
        route 0.0.0.0/0 next-hop 10.0.0.1;
    }
}
